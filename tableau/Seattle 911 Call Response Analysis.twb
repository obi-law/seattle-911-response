    <worksheet name='Map-Severity'>
      <layout-options>
        <title>
          <formatted-text>
            <run fontalignment='1' fontcolor='#eaf1f8'>Call Severity</run>
            <run fontalignment='1'>Æ&#10;</run>
            <run fontalignment='1' fontcolor='#eaf1f8' fontsize='12'><![CDATA[<[federated.1pw1l0s1izdl5k164woq41rg1nw4].[my:originalTimeQueued:ok]>]]></run>
            <run>Æ&#10;</run>
            <run fontcolor='#eaf1f8' fontsize='8'>Warmer = Higher Severity</run>
          </formatted-text>
        </title>
      </layout-options>
      <table>
        <view>
          <datasources>
            <datasource caption='call_data' name='federated.1pw1l0s1izdl5k164woq41rg1nw4' />
            <datasource name='Parameters' />
          </datasources>
          <mapsources>
            <mapsource name='Tableau' />
          </mapsources>
          <datasource-dependencies datasource='Parameters'>
            <column caption='Top N Event Groups' datatype='integer' name='[Parameter 1]' param-domain-type='list' role='measure' type='quantitative' value='10'>
              <calculation class='tableau' formula='10' />
            </column>
          </datasource-dependencies>
          <datasource-dependencies datasource='federated.1pw1l0s1izdl5k164woq41rg1nw4'>
            <column caption='Severity Weight' datatype='real' name='[Calculation_0261151255658498]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='// Severity Weight&#13;&#10;IF ISNULL([priority]) THEN 0&#13;&#10;ELSE&#13;&#10;  CASE INT([priority])&#13;&#10;    WHEN 1 THEN 10&#13;&#10;    WHEN 2 THEN 6&#13;&#10;    WHEN 3 THEN 4&#13;&#10;    WHEN 4 THEN 1&#13;&#10;    ELSE 0.5&#13;&#10;  END&#13;&#10;END' />
            </column>
            <column caption='Severity Load per Day' datatype='real' name='[Calculation_0261151255801859]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='// Severity Load per Day&#13;&#10;SUM([Calculation_0261151255658498])&#13;&#10;/ MIN({ FIXED : COUNTD(DATE([originalTimeQueued])) })' />
            </column>
            <column aggregation='Avg' caption='Dispatch Latitude' datatype='real' name='[dispatchLatitude]' role='measure' semantic-role='[Geographical].[Latitude]' type='quantitative' />
            <column aggregation='Avg' caption='Dispatch Longitude' datatype='real' name='[dispatchLongitude]' role='measure' semantic-role='[Geographical].[Longitude]' type='quantitative' />
            <column caption='Dispatch Neighborhood' datatype='string' name='[dispatchNeighborhood]' role='dimension' type='nominal' />
            <column caption='Event Group' datatype='string' name='[eventGroup]' role='dimension' type='nominal' />
            <column-instance column='[originalTimeQueued]' derivation='Hour' name='[hr:originalTimeQueued:ok]' pivot='key' type='ordinal' />
            <column-instance column='[originalTimeQueued]' derivation='MY' name='[my:originalTimeQueued:ok]' pivot='key' type='ordinal' />
            <column-instance column='[dispatchLatitude]' derivation='None' name='[none:dispatchLatitude:qk]' pivot='key' type='quantitative' />
            <column-instance column='[dispatchLongitude]' derivation='None' name='[none:dispatchLongitude:qk]' pivot='key' type='quantitative' />
            <column-instance column='[dispatchNeighborhood]' derivation='None' name='[none:dispatchNeighborhood:nk]' pivot='key' type='nominal' />
            <column-instance column='[eventGroup]' derivation='None' name='[none:eventGroup:nk]' pivot='key' type='nominal' />
            <column caption='Original Time Queued' datatype='datetime' name='[originalTimeQueued]' role='dimension' type='ordinal' />
            <column caption='Priority' datatype='integer' name='[priority]' role='measure' type='quantitative' />
            <column-instance column='[Calculation_0261151255801859]' derivation='User' name='[usr:Calculation_0261151255801859:qk]' pivot='key' type='quantitative' />
          </datasource-dependencies>
          <filter class='categorical' column='[federated.1pw1l0s1izdl5k164woq41rg1nw4].[Top N Event Group by Date]' filter-group='3'>
            <groupfilter function='level-members' level='[eventGroup]' user:ui-enumeration='all' user:ui-marker='enumerate' />
          </filter>
          <filter class='quantitative' column='[federated.1pw1l0s1izdl5k164woq41rg1nw4].[none:dispatchLatitude:qk]' filter-group='7' included-values='in-range'>
            <min>47.495099420000003</min>
            <max>47.737237260000001</max>
          </filter>
          <filter class='categorical' column='[federated.1pw1l0s1izdl5k164woq41rg1nw4].[none:dispatchNeighborhood:nk]' filter-group='5'>
            <groupfilter function='level-members' level='[none:dispatchNeighborhood:nk]' user:ui-enumeration='all' user:ui-marker='enumerate' />
          </filter>
