      <aliases enabled='yes' />
      <column caption='Avg Calls per Day' datatype='real' default-format='n#,##0;-#,##0' name='[Calculation_0261151248617472]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='COUNTD([cadEventNumber])&#13;&#10;/ MIN({ FIXED : COUNTD(DATE([originalTimeQueued])) })' />
      </column>
      <column caption='Total Calls' datatype='integer' name='[Calculation_0261151251402753]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='COUNTD([cadEventNumber])' />
      </column>
      <column caption='Severity Weight' datatype='real' name='[Calculation_0261151255658498]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='// Severity Weight&#13;&#10;IF ISNULL([priority]) THEN 0&#13;&#10;ELSE&#13;&#10;  CASE INT([priority])&#13;&#10;    WHEN 1 THEN 10&#13;&#10;    WHEN 2 THEN 6&#13;&#10;    WHEN 3 THEN 4&#13;&#10;    WHEN 4 THEN 1&#13;&#10;    ELSE 0.5&#13;&#10;  END&#13;&#10;END' />
      </column>
      <column caption='Severity Load per Day' datatype='real' name='[Calculation_0261151255801859]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='// Severity Load per Day&#13;&#10;SUM([Calculation_0261151255658498])&#13;&#10;/ MIN({ FIXED : COUNTD(DATE([originalTimeQueued])) })' />
      </column>
      <column caption='Hour Order (3AM Start)' datatype='integer' name='[Calculation_0778196207837184]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='([Calculation_2034937709404160] - 3 + 24) % 24' />
        <aliases>
          <alias key='0' value='3 AM' />
          <alias key='1' value='4 AM' />
          <alias key='2' value='5 AM' />
          <alias key='3' value='6 AM' />
          <alias key='4' value='7 AM' />
          <alias key='5' value='8 AM' />
          <alias key='6' value='9 AM' />
          <alias key='7' value='10 AM' />
          <alias key='8' value='11 AM' />
          <alias key='9' value='12 PM' />
          <alias key='10' value='1 PM' />
          <alias key='11' value='2 PM' />
          <alias key='12' value='3 PM' />
          <alias key='13' value='4 PM' />
          <alias key='14' value='5 PM' />
          <alias key='15' value='6 PM' />
          <alias key='16' value='7 PM' />
          <alias key='17' value='8 PM' />
          <alias key='18' value='9 PM' />
          <alias key='19' value='10 PM' />
          <alias key='20' value='11PM' />
          <alias key='21' value='12 AM' />
          <alias key='22' value='1 AM' />
          <alias key='23' value='2 AM' />
        </aliases>
      </column>
      <column caption='Day of Week' datatype='integer' name='[Calculation_0778196208656385]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='DATEPART(&apos;weekday&apos;, [originalTimeQueued])' />
        <aliases>
          <alias key='1' value='Sunday' />
          <alias key='2' value='Monday' />
          <alias key='3' value='Tuesday' />
          <alias key='4' value='Wednesday' />
          <alias key='5' value='Thursday' />
          <alias key='6' value='Friday' />
          <alias key='7' value='Saturday' />
        </aliases>
      </column>
      <column caption='Subset Labels' datatype='string' name='[Calculation_1146807129735168]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [Top N Event Group by Date]&#13;&#10;THEN &quot;Top &quot; + str([Parameters].[Parameter 1])&#13;&#10;ELSE &quot;Others&quot;&#13;&#10;END' />
      </column>
      <column caption='Peak Day Volume' datatype='integer' name='[Calculation_1813112629661696]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='MAX(&#13;&#10;  { FIXED DATE([originalTimeQueued]) : COUNTD([cadEventNumber]) }&#13;&#10;)' />
      </column>
      <column caption='% Domestic Disturbance' datatype='real' default-format='p0.0%' name='[Calculation_1813112629821441]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='COUNTD(IF [eventGroup] = &quot;Domestic Disturbance/Violence&quot; THEN [cadEventNumber] END)&#13;&#10;/ [Calculation_0261151251402753]' />
      </column>
      <column caption='Avg Severity Score' datatype='real' default-format='n#,##0.0;-#,##0.0' name='[Calculation_1813112634712066]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='AVG([Calculation_0261151255658498])   // your existing CASE field' />
      </column>
      <column caption='% High Priority' datatype='real' default-format='p0.0%' name='[Calculation_1813112642646019]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='COUNTD(IF [priority] = 1 THEN [cadEventNumber] END)&#13;&#10;/ [Calculation_0261151251402753]' />
      </column>
      <column caption='Original Time Queued Hour' datatype='integer' datatype-customized='true' name='[Calculation_2034937709404160]' role='dimension' type='ordinal'>
        <calculation class='tableau' formula='DATEPART(&apos;hour&apos;, [originalTimeQueued])' />
        <aliases>
          <alias key='0' value='12 AM' />
          <alias key='1' value='1 AM' />
          <alias key='2' value='2 AM' />
          <alias key='3' value='3 AM' />
          <alias key='4' value='4 AM' />
          <alias key='5' value='5 AM' />
          <alias key='6' value='6 AM' />
          <alias key='7' value='7 AM' />
          <alias key='8' value='8 AM' />
          <alias key='9' value='9 AM' />
          <alias key='10' value='10 AM' />
          <alias key='11' value='11 AM' />
          <alias key='12' value='12 PM' />
          <alias key='13' value='1 PM' />
          <alias key='14' value='2 PM' />
          <alias key='15' value='3 PM' />
          <alias key='16' value='4 PM' />
          <alias key='17' value='5 PM' />
          <alias key='18' value='6 PM' />
          <alias key='19' value='7 PM' />
          <alias key='20' value='8 PM' />
          <alias key='21' value='9 PM' />
          <alias key='22' value='10 PM' />
          <alias key='23' value='11 PM' />
        </aliases>
      </column>
      <column caption='Watch' datatype='string' name='[Calculation_2034937760382978]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF DATEPART(&apos;hour&apos;, [originalTimeQueued]) &gt;= 3 AND &#13;&#10;    DATEPART(&apos;hour&apos;, [originalTimeQueued]) &lt; 11&#13;&#10;        THEN &quot;First Shift&quot;&#13;&#10;ELSEIF DATEPART(&apos;hour&apos;, [originalTimeQueued]) &gt;= 11 AND &#13;&#10;    DATEPART(&apos;hour&apos;, [originalTimeQueued]) &lt; 19&#13;&#10;        THEN &quot;Second Shift&quot;&#13;&#10;ELSEIF DATEPART(&apos;hour&apos;, [originalTimeQueued]) &gt;= 19 OR  &#13;&#10;    DATEPART(&apos;hour&apos;, [originalTimeQueued]) &lt; 3&#13;&#10;        THEN &quot;Third Shift&quot;&#13;&#10;ELSE&#13;&#10;    &quot;Unknown&quot;&#13;&#10;END' />
      </column>
