    <worksheet name='KPI-Avg Severity'>
      <layout-options>
        <title>
          <formatted-text />
        </title>
      </layout-options>
      <table>
        <view>
          <datasources>
            <datasource caption='call_data' name='federated.1pw1l0s1izdl5k164woq41rg1nw4' />
          </datasources>
          <datasource-dependencies datasource='federated.1pw1l0s1izdl5k164woq41rg1nw4'>
            <column caption='Severity Weight' datatype='real' name='[Calculation_0261151255658498]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='// Severity Weight&#13;&#10;IF ISNULL([priority]) THEN 0&#13;&#10;ELSE&#13;&#10;  CASE INT([priority])&#13;&#10;    WHEN 1 THEN 10&#13;&#10;    WHEN 2 THEN 6&#13;&#10;    WHEN 3 THEN 4&#13;&#10;    WHEN 4 THEN 1&#13;&#10;    ELSE 0.5&#13;&#10;  END&#13;&#10;END' />
            </column>
            <column caption='Avg Severity Score' datatype='real' default-format='n#,##0.0;-#,##0.0' name='[Calculation_1813112634712066]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='AVG([Calculation_0261151255658498])   // your existing CASE field' />
            </column>
            <column caption='Dispatch Neighborhood' datatype='string' name='[dispatchNeighborhood]' role='dimension' type='nominal' />
            <column-instance column='[originalTimeQueued]' derivation='MY' name='[my:originalTimeQueued:ok]' pivot='key' type='ordinal' />
            <column-instance column='[dispatchNeighborhood]' derivation='None' name='[none:dispatchNeighborhood:nk]' pivot='key' type='nominal' />
            <column caption='Original Time Queued' datatype='datetime' name='[originalTimeQueued]' role='dimension' type='ordinal' />
            <column caption='Priority' datatype='integer' name='[priority]' role='measure' type='quantitative' />
            <column-instance column='[Calculation_1813112634712066]' derivation='User' name='[usr:Calculation_1813112634712066:qk]' pivot='key' type='quantitative' />
          </datasource-dependencies>
          <filter class='categorical' column='[federated.1pw1l0s1izdl5k164woq41rg1nw4].[none:dispatchNeighborhood:nk]' filter-group='5'>
            <groupfilter function='level-members' level='[none:dispatchNeighborhood:nk]' user:ui-enumeration='all' user:ui-marker='enumerate' />
          </filter>
          <slices>
            <column>[federated.1pw1l0s1izdl5k164woq41rg1nw4].[my:originalTimeQueued:ok]</column>
            <column>[federated.1pw1l0s1izdl5k164woq41rg1nw4].[none:dispatchNeighborhood:nk]</column>
          </slices>
          <aggregation value='true' />
        </view>
        <style>
          <style-rule element='cell'>
            <format attr='text-align' value='center' />
          </style-rule>
          <style-rule element='table'>
            <format attr='background-color' value='#00000000' />
          </style-rule>
        </style>
        <panes>
          <pane selection-relaxation-option='selection-relaxation-allow'>
            <view>
              <breakdown value='auto' />
            </view>
            <mark class='Text' />
            <encodings>
              <text column='[federated.1pw1l0s1izdl5k164woq41rg1nw4].[usr:Calculation_1813112634712066:qk]' />
            </encodings>
            <customized-tooltip>
              <formatted-text>
                <run bold='true'>Severity is a weight added to Priority.</run>
                <run>Æ&#10;</run>
                <run bold='true'>Priority Score</run>
                <run>Æ&#10;</run>
                <run bold='true'>	1 = highest receives severity score of 10</run>
                <run>Æ&#10;</run>
                <run bold='true'>&#9;...</run>
                <run>Æ&#10;</run>
                <run bold='true'>	4 = lowest receives severity score of 1</run>
                <run>Æ&#10;</run>
                <run bold='true'>&#9;5 through 9 are de minimus.</run>
              </formatted-text>
            </customized-tooltip>
            <customized-label>
              <formatted-text>
                <run fontcolor='#eaf1f8' fontsize='30'><![CDATA[<[federated.1pw1l0s1izdl5k164woq41rg1nw4].[usr:Calculation_1813112634712066:qk]>]]></run>
                <run>Æ&#10;</run>
                <run fontcolor='#98a6b0' fontsize='11'>AVG SEVERITY SCORE</run>
              </formatted-text>
            </customized-label>
            <style>
              <style-rule element='mark'>
                <format attr='mark-labels-show' value='true' />
                <format attr='mark-labels-cull' value='true' />
              </style-rule>
            </style>
          </pane>
        </panes>
        <rows />
        <cols />
      </table>
      <simple-id uuid='{91BC8973-0EA8-45B2-B40C-84C3BE5B32AA}' />
    </worksheet>
